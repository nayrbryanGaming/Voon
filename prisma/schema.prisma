generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  clerkId           String?          @unique
  username          String?          @unique
  passwordHash      String?
  email             String           @unique
  name              String
  avatarUrl         String?
  role              UserRole         @default(STUDENT)
  campusId          String?
  campus            Campus?          @relation(fields: [campusId], references: [id], onDelete: SetNull)
  subscriptionTier  SubscriptionTier @default(FREE)
  apiTokenEncrypted String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  hostedMeetings    Meeting[]     @relation("Host")
  participations    Participant[]
  attendanceRecords Attendance[]
  recordings        Recording[]

  @@index([clerkId])
  @@index([username])
  @@index([email])
  @@index([campusId])
}

enum UserRole {
  STUDENT
  LECTURER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model Campus {
  id       String    @id @default(cuid())
  name     String
  domain   String?   @unique
  logoUrl  String?
  users    User[]
  meetings Meeting[]
}

model Meeting {
  id              String        @id @default(cuid())
  title           String
  description     String?
  roomId          String        @unique @default(cuid())
  hostId          String
  host            User          @relation("Host", fields: [hostId], references: [id], onDelete: Cascade)
  campusId        String?
  campus          Campus?       @relation(fields: [campusId], references: [id], onDelete: SetNull)
  startTime       DateTime
  endTime         DateTime?
  duration        Int?
  status          MeetingStatus @default(SCHEDULED)
  isRecorded      Boolean       @default(false)
  recordingUrl    String?
  maxParticipants Int?
  isPublic        Boolean       @default(false)
  inviteCode      String        @unique @default(cuid())
  // Host-configured permissions (persisted for rejoin)
  screenShareLocked Boolean     @default(false)
  videoStreamLocked Boolean     @default(false)
  createdAt       DateTime      @default(now())

  participants Participant[]
  attendance   Attendance[]
  transcript   Transcript?
  summary      MeetingSummary?
  polls        Poll[]
  recordings   Recording[]
  whiteboardId String?

  @@index([hostId])
  @@index([roomId])
  @@index([status])
  @@index([startTime])
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Recording {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  s3Key       String?
  storageUrl  String?
  fileSize    BigInt?
  durationSec Int?
  egressId    String?
  quality     String   @default("original")
  createdAt   DateTime @default(now())

  @@index([meetingId])
  @@index([userId])
  @@index([egressId])
}

model Participant {
  id        String          @id @default(cuid())
  meetingId String
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime        @default(now())
  leftAt    DateTime?
  role      ParticipantRole @default(ATTENDEE)
  isMuted   Boolean         @default(false)
  isVideoOn Boolean         @default(true)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

enum ParticipantRole {
  HOST
  CO_HOST
  PRESENTER
  ATTENDEE
}

model Attendance {
  id        String           @id @default(cuid())
  meetingId String
  meeting   Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime
  leftAt    DateTime?
  duration  Int?
  status    AttendanceStatus @default(PRESENT)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

model Transcript {
  id        String   @id @default(cuid())
  meetingId String   @unique
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  content   String
  speakers  Json?
  createdAt DateTime @default(now())

  @@index([meetingId])
}

model MeetingSummary {
  id          String   @id @default(cuid())
  meetingId   String   @unique
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  summary     String
  keyPoints   String[]
  actionItems String[]
  topics      String[]
  sentiment   String?
  createdAt   DateTime @default(now())

  @@index([meetingId])
}

model Poll {
  id        String   @id @default(cuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  question  String
  options   String[]
  votes     Json?
  isAnon    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([meetingId])
}
