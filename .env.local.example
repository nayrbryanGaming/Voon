# ─── CLERK AUTH ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_xxxx

# ─── LIVEKIT ────────────────────────────────────────────
LIVEKIT_API_KEY=APIxxxx
LIVEKIT_API_SECRET=xxxx
NEXT_PUBLIC_LIVEKIT_URL=wss://your-app.livekit.cloud
# LIVEKIT_URL is optional — auto-derived from NEXT_PUBLIC_LIVEKIT_URL (wss→https)
# Set only if your LiveKit HTTP endpoint differs from the WSS URL
# LIVEKIT_URL=https://your-app.livekit.cloud

# ─── SUPABASE ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx
DATABASE_URL=postgresql://postgres:xxxx@db.xxxx.supabase.co:5432/postgres

# ─── AI PROVIDER (pilih salah satu atau keduanya) ───────
# Groq = GRATIS, ultra-cepat (Llama 3.1) — https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxx
# Anthropic = Claude premium (opsional, untuk fallback)
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── ENCRYPTION (wajib untuk keamanan token API user) ───
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Harus 64 karakter hex (32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── S3 RECORDING (opsional — gunakan jika bukan Supabase Storage) ──
# S3_BUCKET=voon-recordings
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=AKIAxxxx
# S3_SECRET_KEY=xxxx

# ─── APP ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://voon.vercel.app
NEXT_PUBLIC_APP_NAME=Voon

# ─── NEXTAUTH ───────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-random
NEXTAUTH_URL=https://voon.vercel.app
