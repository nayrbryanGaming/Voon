{
  "functions": {
    "src/app/api/ai/**": {
      "maxDuration": 60
    },
    "src/app/api/livekit/**": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/room/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=*, microphone=*, display-capture=*"
        }
      ]
    }
  ]
}
